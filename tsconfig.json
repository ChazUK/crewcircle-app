{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/assets/*": ["./src/assets/*"],
      "@/data/*": ["./src/data/*"],
      "@/*": ["./src/*"],
      "@convex/api": ["./convex/_generated/api"],
      "@convex/server": ["./convex/_generated/server"],
      "@convex/*": ["./convex/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
