{
  "expo": {
    "name": "crew-circle-app",
    "slug": "crew-circle-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/ios-light.png",
    "scheme": "crew-circle",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/icons/splash-icon-light.png",
      "resizeMode": "contain",
      "backgroundColor": "#232323"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.crewcircle.crewcircle"
    },
    "android": {
      "icon": "./src/assets/icons/adaptive-icon.png",
      "predictiveBackGestureEnabled": false,
      "package": "com.crewcircle.crewcircle"
    },
    "plugins": [
      "@clerk/expo",
      "expo-image",
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#232323",
          "image": "./src/assets/icons/splash-icon.png",
          "dark": {
            "image": "./src/assets/icons/splash-icon-dark.png",
            "backgroundColor": "#000000"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
